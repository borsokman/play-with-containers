  "info": {
    "_postman_id": "b703046f-6886-4164-8030-da63cfd8db1e",
    "name": "crud-master API tests",
    "description": "This collection provides comprehensive testing coverage for a microservices architecture consisting of three core APIs: Inventory, Billing, and Gateway. It contains 10 test requests organized into three logical folders:\n\n- **Inventory API tests** - CRUD operations for movie management, including endpoints to retrieve all movies, get a specific movie, add new movies, update existing movies, and delete movies.\n    \n- **Billing API tests** - Billing system operations including gateway status checks and billing validation endpoints.\n    \n- **Gateway API tests** - API gateway routing functionality, including proxy routing, message queue routing, and service availability testing.\n    \n\nThe collection is designed to validate the core functionality of these APIs through standard HTTP methods (GET, POST, PUT, DELETE) and includes error handling scenarios such as service unavailability testing. This collection serves as a testing suite for development and quality assurance workflows.\n\nUse `{{base_url}}/api/movies` and `{{base_url}}/api/billing` in all your requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53619934",
    "_collection_link": "https://go.postman.co/collection/53619934-b703046f-6886-4164-8030-da63cfd8db1e?source=collection_link"
  },
