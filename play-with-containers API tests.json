              "script": {
                "exec": [
                  "pm.test(\"Gateway successfully proxied to Inventory\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Verify proxy headers are cleaned\", function () {",
                  "    // Ensuring 'transfer-encoding' was removed as per your code logic",
                  "    pm.expect(pm.response.headers.get(\"transfer-encoding\")).to.be.undefined;",
