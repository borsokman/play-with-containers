INVENTORY_DB_PASSWORD=your_secure_password
INVENTORY_DB_HOST=inventory-db
INVENTORY_DB_PORT=5432

# Billing Database
BILLING_DB_NAME=billing_db
BILLING_DB_USER=orders_user
